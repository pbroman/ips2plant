<idea-plugin>
    <id>com.github.pbroman.ips2plant</id>
    <name>IPS to PlantUML</name>
    <vendor>pbroman</vendor>
    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService serviceImplementation="com.github.pbroman.ips2plant.settings.Ips2PlantSettings"/>
        <applicationConfigurable parentId="tools"
                                 instance="com.github.pbroman.ips2plant.settings.Ips2PlantConfigurable"
                                 id="com.github.pbroman.ips2plant.settings.Ips2PlantConfigurable"
                                 displayName="IPS to PlantUML"/>
        <toolWindow id="IPS to PlantUML"
                    factoryClass="com.github.pbroman.ips2plant.ui.Ips2PlantToolWindowFactory"
                    anchor="right"
                    icon="AllIcons.FileTypes.Diagram"/>
    </extensions>

</idea-plugin>